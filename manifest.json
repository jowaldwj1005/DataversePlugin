{
  "manifest_version": 3,
  "name": "Dataverse Toolkit",
  "short_name": "DV Toolkit",
  "version": "1.0.0",
  "author": "jwald",
  "description": "Professional Dataverse Web API explorer, FetchXML builder, and developer toolkit",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.dynamics.com/*",
    "https://*.powerapps.com/*",
    "https://*.powerplatform.com/*",
    "https://*.microsoftdynamics.com/*",
    "https://*.openai.com/*",
    "https://*.openai.azure.com/*",
    "https://api.anthropic.com/*"
  ],
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": [
        "https://*.dynamics.com/*",
        "https://*.powerapps.com/*",
        "https://*.powerplatform.com/*",
        "https://*.microsoftdynamics.com/*"
      ],
      "js": ["src/content/content-script.js"],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://*.dynamics.com/*",
        "https://*.powerapps.com/*",
        "https://*.powerplatform.com/*",
        "https://*.microsoftdynamics.com/*"
      ],
      "js": ["src/content/page-extractor.js"],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "devtools_page": "src/devtools/devtools.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": ["src/*"],
      "matches": [
        "https://*.dynamics.com/*",
        "https://*.powerapps.com/*",
        "https://*.powerplatform.com/*",
        "https://*.microsoftdynamics.com/*"
      ]
    }
  ]
}
